---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMeta } from '../data/site';

export async function getStaticPaths() {
  const experiences = await getCollection('experiences');

  return experiences.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

interface Props {
  entry: CollectionEntry<'experiences'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="space-y-10">
    <section class="grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-end">
      <div>
        <p class="eyebrow">Experience Detail</p>
        <h1 class="type-display mt-5 text-ink">
          {entry.data.title}
        </h1>
        <p class="type-body mt-6 max-w-2xl text-ink/72">
          {entry.data.summary}
        </p>
      </div>

      <div class="surface-card p-6 sm:p-7">
        <p class="type-label-wide uppercase text-ink/40">Meta</p>
        <div class="mt-4 flex flex-wrap gap-2">
          <span class="chip">{entry.data.organization}</span>
          <span class="chip">{entry.data.period}</span>
          {entry.data.focus.map((item) => <span class="chip">{item}</span>)}
        </div>

        <div class="mt-7">
          <a href={siteMeta.rootPath} class="button-primary type-small px-4 py-2">
            목록으로 돌아가기
          </a>
        </div>
      </div>
    </section>

    <section class="surface-card p-8 sm:p-10 lg:p-12">
      <div class="rich-text mx-auto max-w-3xl">
        <Content />
      </div>
    </section>
  </article>
</BaseLayout>
