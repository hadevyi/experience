---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMeta } from '../data/site';
import {
  experienceRelationLabels,
  formatExperiencePeriods,
  getExperienceEmploymentTypeLabel,
  getExperienceDetailSections,
  getExperiencePairs,
  getLocalizedEntry,
  getLocalizedLink,
  getLocalizedListItem,
  getLocalizedText,
  resolveExperienceStatus,
  statusLabels
} from '../data/experienceArchive';
import {
  getProjectDomainLabel,
  getExperienceCategoryLabel,
  getExperienceTagLabel
} from '../data/experienceTaxonomy';

const i18nText = (ko: string, en: string) => ({
  'data-i18n-ko': ko,
  'data-i18n-en': en
});

const i18nAttr = (attr: string, ko: string, en: string) => ({
  'data-i18n-attr': attr,
  'data-i18n-ko': ko,
  'data-i18n-en': en
});

const localized = (value: { ko: string; en: string }) => i18nText(value.ko, value.en);
const tagAriaLabel = (tag: { ko: string; en: string; description: { ko: string; en: string } }) =>
  i18nAttr('aria-label', `${tag.ko}: ${tag.description.ko}`, `${tag.en}: ${tag.description.en}`);

export async function getStaticPaths() {
  const experiences = getExperiencePairs(await getCollection('experiences'));

  return experiences.map((entry) => ({
    params: { slug: entry.number },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const koContent = await render(getLocalizedEntry(entry, 'ko'));
const enContent = await render(getLocalizedEntry(entry, 'en'));
const KoContent = koContent.Content;
const EnContent = enContent.Content;
const allExperiencePairs = getExperiencePairs(await getCollection('experiences'));
const experienceByNumber = new Map(allExperiencePairs.map((item) => [item.number, item]));
const title = getLocalizedText(entry, 'title');
const summary = getLocalizedText(entry, 'summary');
const oneLine = getLocalizedText(entry, 'oneLine');
const shouldShowSummary =
  summary.ko.trim().length > 0 &&
  summary.en.trim().length > 0 &&
  (summary.ko.trim() !== oneLine.ko.trim() || summary.en.trim() !== oneLine.en.trim());
const organization = getLocalizedText(entry, 'organization');
const categoryLabel = getExperienceCategoryLabel(entry.meta.category);
const experienceTagLabels = (entry.meta.experienceTags ?? []).map((tag) => getExperienceTagLabel(tag));
const projectDomainLabels = (entry.meta.projectDomains ?? []).map((domain) => getProjectDomainLabel(domain));
const periodLabel = {
  ko: formatExperiencePeriods(entry.meta, 'ko'),
  en: formatExperiencePeriods(entry.meta, 'en')
};
const isCertification = entry.meta.category === 'certification';
const detailPeriodLabel = isCertification
  ? {
      ko: '취득일',
      en: 'Acquired'
    }
  : {
      ko: '기간',
      en: 'Period'
    };
const detailOrganizationLabel = isCertification
  ? {
      ko: '발급기관',
      en: 'Issuer'
    }
  : {
      ko: '기관',
      en: 'Organization'
    };
const statusLabel = statusLabels[resolveExperienceStatus(entry.meta.status)];
const isInProgress = entry.meta.status === 'in-progress';
const inProgressDetailVisibility = entry.meta.inProgressDetailVisibility ?? 'private';
const shouldHideAllInProgressSections = isInProgress && inProgressDetailVisibility === 'private';
const shouldLimitInProgressSections = isInProgress && inProgressDetailVisibility !== 'full';
const employmentTypeLabel =
  entry.meta.category === 'work-experience' && entry.meta.employmentType
    ? getExperienceEmploymentTypeLabel(entry.meta.employmentType)
    : null;
const koProject = entry.ko.data.project;
const enProject = (entry.en ?? entry.ko).data.project ?? koProject;
const koCertification = entry.ko.data.certification;
const enCertification = (entry.en ?? entry.ko).data.certification ?? koCertification;
const projectTechCategoryLabels = {
  frontend: {
    ko: '프론트엔드',
    en: 'Frontend'
  },
  backend: {
    ko: '백엔드/API',
    en: 'Backend / API'
  },
  infra: {
    ko: '인프라',
    en: 'Infra'
  },
  design: {
    ko: '디자인/협업',
    en: 'Design / Collaboration'
  },
  language: {
    ko: '언어',
    en: 'Language'
  },
  framework: {
    ko: '프레임워크',
    en: 'Framework'
  },
  database: {
    ko: '데이터베이스',
    en: 'Database'
  },
  tool: {
    ko: '도구',
    en: 'Tool'
  },
  environment: {
    ko: '개발환경',
    en: 'Environment'
  },
  platform: {
    ko: '플랫폼',
    en: 'Platform'
  },
  other: {
    ko: '기타',
    en: 'Other'
  }
} as const;
const projectTechStackItems = (koProject?.techStack ?? []).map((item, index) => {
  const enItem = enProject?.techStack?.[index] ?? item;
  const category = item.category ?? 'other';

  return {
    category,
    categoryLabel: projectTechCategoryLabels[category],
    ko: item,
    en: enItem
  };
});
const projectTechStackGroups = projectTechStackItems.reduce<
  Array<{
    category: string;
    categoryLabel: (typeof projectTechCategoryLabels)[keyof typeof projectTechCategoryLabels];
    items: typeof projectTechStackItems;
  }>
>((groups, item) => {
  const existingGroup = groups.find((group) => group.category === item.category);

  if (existingGroup) {
    existingGroup.items.push(item);
    return groups;
  }

  groups.push({
    category: item.category,
    categoryLabel: item.categoryLabel,
    items: [item]
  });

  return groups;
}, []);
const hasProjectTechStack = entry.meta.category === 'project' && projectTechStackItems.length > 0;
const koAwardScholarship = entry.ko.data.awardScholarship;
const enAwardScholarship = (entry.en ?? entry.ko).data.awardScholarship ?? koAwardScholarship;
const awardCriteriaItems = (koAwardScholarship?.criteria ?? []).map((item, index) => ({
  ko: item,
  en: enAwardScholarship?.criteria?.[index] ?? item
}));
const hasAwardCriteria = entry.meta.category === 'award-scholarship' && awardCriteriaItems.length > 0;
const formatProjectDomainValue = (language: 'ko' | 'en') =>
  projectDomainLabels.map((item) => item[language]).filter(Boolean).join(', ');
const formatProjectTeamSize = (language: 'ko' | 'en') => {
  if (!entry.meta.teamSize) {
    return '';
  }

  if (language === 'ko') {
    return `${entry.meta.teamSize}인`;
  }

  return entry.meta.teamSize === 1 ? '1 person' : `${entry.meta.teamSize} people`;
};
const projectInfoRows =
  entry.meta.category === 'project' && koProject
    ? [
        {
          label: { ko: '도메인', en: 'Domain' },
          value: {
            ko: formatProjectDomainValue('ko'),
            en: formatProjectDomainValue('en')
          }
        },
        {
          label: { ko: '소속/주최', en: 'Host' },
          value: { ko: koProject.host, en: enProject?.host || koProject.host }
        },
        {
          label: { ko: '참여 인원', en: 'Team Size' },
          value: { ko: formatProjectTeamSize('ko'), en: formatProjectTeamSize('en') }
        },
        {
          label: { ko: '직책/역할', en: 'Position / Role' },
          value: { ko: koProject.position, en: enProject?.position || koProject.position }
        },
        {
          label: { ko: '배포/실행', en: 'Run / Deployment' },
          value: { ko: koProject.deployment, en: enProject?.deployment || koProject.deployment }
        }
      ].filter((item) => item.value.ko.trim().length > 0 || item.value.en.trim().length > 0)
    : [];
const certificationInfoRows =
  entry.meta.category === 'certification' && koCertification
    ? [
        {
          label: { ko: '주관기관', en: 'Responsible Agency' },
          value: {
            ko: koCertification.responsibleAgency ?? '',
            en: enCertification?.responsibleAgency || koCertification.responsibleAgency || ''
          }
        },
        {
          label: { ko: '시행기관', en: 'Administering Organization' },
          value: {
            ko: koCertification.administeringOrganization ?? '',
            en: enCertification?.administeringOrganization || koCertification.administeringOrganization || ''
          }
        }
      ].filter((item) => item.value.ko.trim().length > 0 || item.value.en.trim().length > 0)
    : [];
const detailInfoRows = projectInfoRows.length > 0 ? projectInfoRows : certificationInfoRows;
const representativeImage = entry.meta.representativeImage;
const representativeImageAlt = {
  ko: representativeImage?.alt?.ko ?? title.ko,
  en: representativeImage?.alt?.en ?? title.en
};
const structuredSections = getExperienceDetailSections(entry);
const structuredDetailBlocks = structuredSections.flatMap((section, index) => {
  const blocks = [{ type: 'section', section }] as Array<
    | { type: 'section'; section: (typeof structuredSections)[number] }
    | { type: 'techStack' }
    | { type: 'awardCriteria' }
  >;

  if (index === 0 && hasProjectTechStack) {
    blocks.push({ type: 'techStack' });
  }

  if (hasAwardCriteria && section.ko.label === '선정 기준') {
    return [{ type: 'awardCriteria' }] as Array<
      | { type: 'section'; section: (typeof structuredSections)[number] }
      | { type: 'techStack' }
      | { type: 'awardCriteria' }
    >;
  }

  return blocks;
});
const isWorkExperience = entry.meta.category === 'work-experience';
const workResponsibilityLabels = new Set(['맡은 일', 'Responsibilities']);
const stripListMarker = (line: string) => line.replace(/^[•-]\s*/, '').trim();
const splitDetailLines = (body: string) =>
  body
    .split('\n')
    .map((line) => stripListMarker(line))
    .filter((line) => line.length > 0);
const splitDetailParagraphs = (body: string) =>
  body
    .split(/\n{2,}/)
    .map((paragraph) => paragraph.trim())
    .filter((paragraph) => paragraph.length > 0);
const isBulletParagraph = (paragraph: string) => {
  const lines = paragraph.split('\n').map((line) => line.trim()).filter(Boolean);

  return lines.length > 0 && lines.every((line) => line.startsWith('- ') || line.startsWith('• '));
};
const splitBulletItems = (paragraph: string) =>
  paragraph
    .split('\n')
    .map((line) => stripListMarker(line))
    .filter((line) => line.length > 0);
const getSectionContentBlocks = (section: (typeof structuredSections)[number]) => {
  const koParagraphs = splitDetailParagraphs(section.ko.body);
  const enParagraphs = splitDetailParagraphs(section.en.body);

  return koParagraphs.map((ko, index) => {
    const en = enParagraphs[index] ?? ko;

    if (isBulletParagraph(ko)) {
      const koItems = splitBulletItems(ko);
      const enItems = isBulletParagraph(en) ? splitBulletItems(en) : koItems;

      return {
        type: 'list' as const,
        items: koItems.map((koItem, itemIndex) => ({
          ko: koItem,
          en: enItems[itemIndex] ?? koItem
        }))
      };
    }

    return {
      type: 'paragraph' as const,
      ko,
      en
    };
  });
};
const getSectionTextItems = (section: (typeof structuredSections)[number]) => {
  const koLines = splitDetailLines(section.ko.body);
  const enLines = splitDetailLines(section.en.body);
  const isKoList = section.ko.body
    .split('\n')
    .some((line) => line.trim().startsWith('•') || line.trim().startsWith('-'));

  if (!isKoList || koLines.length < 2) {
    return [];
  }

  return koLines.map((ko, index) => ({
    ko,
    en: enLines[index] ?? ko
  }));
};
const isWorkResponsibilitySection = (section: (typeof structuredSections)[number]) =>
  workResponsibilityLabels.has(section.ko.label) || workResponsibilityLabels.has(section.en.label);
const inProgressVisibleSectionLabels: Record<string, Set<string>> = {
  affiliation: new Set(['소속/기관 소개', '속하게 된 이유', '합류 당시']),
  project: new Set(['프로젝트 개요', '팀 구성', '기술 스택']),
  community: new Set(['활동/커뮤니티 소개', '참여한 이유', '맡은 역할']),
  'work-experience': new Set(['조직과 책임']),
  'event-operation': new Set(['행사 개요', '운영 배경', '맡은 역할']),
  'learning-growth': new Set(['학습이 필요했던 이유', '당시의 이해 수준', '배운 내용']),
  certification: new Set(['자격/인증 개요', '발급 기관', '인증 범위']),
  'teaching-mentoring': new Set(['대상', '참여하게 된 이유', '전달한 내용']),
  'award-scholarship': new Set(['수상/장학 개요', '선정 기준']),
  'media-interview': new Set(['소개된 배경', '당시 맥락', '다룬 주제'])
};
const inProgressPrivatePlaceholderBlockCount: Record<string, number> = {
  affiliation: 5,
  project: 7,
  community: 6,
  'work-experience': 4,
  'event-operation': 8,
  'learning-growth': 5,
  certification: 6,
  'teaching-mentoring': 6,
  'award-scholarship': 4,
  'media-interview': 5
};
const isInProgressVisibleBlock = (block: (typeof structuredDetailBlocks)[number]) => {
  if (shouldHideAllInProgressSections) {
    return false;
  }

  if (!shouldLimitInProgressSections) {
    return true;
  }

  if (block.type === 'techStack') {
    return inProgressVisibleSectionLabels.project.has('기술 스택');
  }

  if (block.type === 'awardCriteria') {
    return inProgressVisibleSectionLabels['award-scholarship'].has('선정 기준');
  }

  return inProgressVisibleSectionLabels[entry.meta.category]?.has(block.section.ko.label) ?? false;
};
const visibleStructuredDetailBlocks = structuredDetailBlocks.filter(isInProgressVisibleBlock);
const hiddenStructuredDetailBlockCount = shouldLimitInProgressSections
  ? shouldHideAllInProgressSections
    ? Math.max(
        structuredDetailBlocks.length,
        inProgressPrivatePlaceholderBlockCount[entry.meta.category] ?? 3
      )
    : structuredDetailBlocks.length - visibleStructuredDetailBlocks.length
  : 0;
const hasStructuredDetailBody = structuredSections.length > 0 || hiddenStructuredDetailBlockCount > 0;
const parseLabeledWorkItem = (value: string) => {
  const separatorIndex = value.search(/[:：]/);

  if (separatorIndex <= 0 || separatorIndex > 28) {
    return {
      label: '',
      body: value
    };
  }

  return {
    label: value.slice(0, separatorIndex).trim(),
    body: value.slice(separatorIndex + 1).trim()
  };
};
const getWorkResponsibilityCards = (section: (typeof structuredSections)[number]) =>
  getSectionTextItems(section).map((item) => {
    const ko = parseLabeledWorkItem(item.ko);
    const en = parseLabeledWorkItem(item.en);

    return {
      ko: {
        label: ko.label,
        body: ko.body
      },
      en: {
        label: en.label || ko.label,
        body: en.body || ko.body
      }
    };
  });
const highlights = entry.ko.data.highlights.map((_, index) =>
  getLocalizedListItem(entry, 'highlights', index)
).filter(
  (highlight) => highlight.ko.trim().length > 0 || highlight.en.trim().length > 0
);
const links = entry.ko.data.links.map((_, index) =>
  getLocalizedLink(entry, index)
);
const relatedItems = (entry.meta.related ?? []).map((item) => {
  const relatedEntry = experienceByNumber.get(item.number);
  const relationLabel = experienceRelationLabels[item.relation ?? 'related'];
  const relatedTitle = relatedEntry
    ? getLocalizedText(relatedEntry, 'title')
    : {
        ko: item.number,
        en: item.number
      };
  const relatedPeriodLabel = relatedEntry
    ? {
        ko: formatExperiencePeriods(relatedEntry.meta, 'ko'),
        en: formatExperiencePeriods(relatedEntry.meta, 'en')
      }
    : {
        ko: '',
        en: ''
      };
  const note = {
    ko: item.note?.ko ?? '',
    en: item.note?.en ?? item.note?.ko ?? ''
  };

  return {
    ...item,
    href: relatedEntry ? `${siteMeta.rootPath}${relatedEntry.number}/` : '',
    relationLabel,
    title: relatedTitle,
    periodLabel: relatedPeriodLabel,
    note
  };
}).sort((a, b) => Number(a.number) - Number(b.number));
---

<BaseLayout
  title={title.ko}
  description={summary.ko}
  showHeader={false}
  mainClass="experience-detail-main mx-auto w-full max-w-[62rem] px-5 pb-24 pt-5 sm:px-8 lg:px-10"
>
  <article class="experience-detail-page">
    <nav class="experience-detail-nav" {...i18nAttr('aria-label', '경험 상세 탐색', 'Experience detail navigation')}>
      <a href={siteMeta.rootPath} class="experience-back-link">
        <span aria-hidden="true">←</span>
        <span {...i18nText('목록으로 돌아가기', 'Back to list')}>목록으로 돌아가기</span>
      </a>
    </nav>

    <section class="experience-detail-hero">
      <div class="experience-detail-hero-main">
        <p class="experience-detail-kicker">
          <span>{entry.meta.number}</span>
          <span aria-hidden="true">/</span>
          <span {...localized(categoryLabel)}>{categoryLabel.ko}</span>
        </p>
        <h1 class="experience-detail-title" {...localized(title)}>
          {title.ko}
        </h1>
        {
          (oneLine.ko || oneLine.en) && (
            <p class="experience-detail-one-line" {...localized(oneLine)}>
              {oneLine.ko}
            </p>
          )
        }
        {
          shouldShowSummary && (
            <p class="experience-detail-summary" {...localized(summary)}>
              {summary.ko}
            </p>
          )
        }

        {
          links.length > 0 && (
            <div class="experience-detail-hero-links" {...i18nAttr('aria-label', '공개 링크', 'Public links')}>
              <div class="experience-detail-hero-link-list">
                {links.map((link) => (
                  <a href={link.ko.url} class="experience-detail-hero-link" rel="noreferrer">
                    <span {...i18nText(link.ko.label, link.en.label)}>{link.ko.label}</span>
                    <span aria-hidden="true">↗</span>
                  </a>
                ))}
              </div>
            </div>
          )
        }

        {
          highlights.length > 0 && (
            <ul class="experience-detail-highlight-list">
              {highlights.map((highlight) => (
                <li>
                  <span aria-hidden="true" />
                  <span {...i18nText(highlight.ko, highlight.en)}>{highlight.ko}</span>
                </li>
              ))}
            </ul>
          )
        }
      </div>

      <aside class="experience-detail-record-card" {...i18nAttr('aria-label', '경험 기본 정보', 'Experience information')}>
        {
          representativeImage && (
            <figure class="experience-detail-image-card">
              <img src={representativeImage.src} {...i18nAttr('alt', representativeImageAlt.ko, representativeImageAlt.en)} />
            </figure>
          )
        }

        <dl class="experience-detail-info">
          <div>
            <dt {...localized(detailPeriodLabel)}>{detailPeriodLabel.ko}</dt>
            <dd {...localized(periodLabel)}>{periodLabel.ko}</dd>
          </div>
          {
            detailInfoRows.length > 0 ? (
              detailInfoRows.map((item) => (
                <div>
                  <dt {...localized(item.label)}>{item.label.ko}</dt>
                  <dd {...localized(item.value)}>{item.value.ko}</dd>
                </div>
              ))
            ) : (
              <div>
                <dt {...localized(detailOrganizationLabel)}>{detailOrganizationLabel.ko}</dt>
                <dd {...localized(organization)}>{organization.ko}</dd>
              </div>
            )
          }
          {
            employmentTypeLabel && (
              <div>
                <dt {...i18nText('형태', 'Type')}>형태</dt>
                <dd {...localized(employmentTypeLabel)}>{employmentTypeLabel.ko}</dd>
              </div>
            )
          }
          <div>
            <dt {...i18nText('상태', 'Status')}>상태</dt>
            <dd {...i18nText(statusLabel.ko, statusLabel.en)}>{statusLabel.ko}</dd>
          </div>
        </dl>

        <div class="experience-detail-chip-group">
          {
            experienceTagLabels.map((tag) => (
              <span class="chip experience-tag-chip" {...tagAriaLabel(tag)}>
                <span {...localized(tag)}>{tag.ko}</span>
                <span class="experience-tag-tooltip" aria-hidden="true">
                  <span {...localized(tag.description)}>{tag.description.ko}</span>
                </span>
              </span>
            ))
          }
        </div>
      </aside>
    </section>

    <section class:list={['experience-detail-body', isInProgress && 'experience-detail-body-in-progress']}>
      {
        hasStructuredDetailBody ? (
          <div class="experience-detail-section-list">
            {(isInProgress ? visibleStructuredDetailBlocks : structuredDetailBlocks).map((block, index) =>
              block.type === 'techStack' ? (
                <section class="experience-detail-section experience-detail-tech-section">
                  <span class="experience-detail-section-number">{String(index + 1).padStart(2, '0')}</span>
                  <div class="experience-detail-section-content experience-detail-tech-content">
                    <h2 class="experience-detail-section-label" {...i18nText('기술 스택', 'Tech Stack')}>기술 스택</h2>
                    <div class="experience-detail-tech-grid">
                      {projectTechStackGroups.map((group) => (
                        <article class="experience-detail-tech-card experience-detail-tech-group-card">
                          <p class="experience-detail-tech-category" {...localized(group.categoryLabel)}>
                            {group.categoryLabel.ko}
                          </p>
                          <div class="experience-detail-tech-item-list">
                            {group.items.map((item) => (
                              <div class="experience-detail-tech-item">
                                <h3 class="experience-detail-tech-name" {...i18nText(item.ko.name, item.en.name)}>
                                  {item.ko.name}
                                </h3>
                                {(item.ko.version || item.en.version) && (
                                  <p class="experience-detail-tech-version" {...i18nText(item.ko.version, item.en.version)}>
                                    {item.ko.version}
                                  </p>
                                )}
                                {(item.ko.note || item.en.note) && (
                                  <p class="experience-detail-tech-note" {...i18nText(item.ko.note, item.en.note)}>
                                    {item.ko.note}
                                  </p>
                                )}
                              </div>
                            ))}
                          </div>
                        </article>
                      ))}
                    </div>
                  </div>
                </section>
              ) : block.type === 'awardCriteria' ? (
                <section class="experience-detail-section experience-detail-tech-section experience-detail-award-criteria-section">
                  <span class="experience-detail-section-number">{String(index + 1).padStart(2, '0')}</span>
                  <div class="experience-detail-section-content experience-detail-tech-content">
                    <h2 class="experience-detail-section-label" {...i18nText('선정 기준', 'Selection Criteria')}>선정 기준</h2>
                    <div class="experience-detail-tech-grid experience-detail-award-criteria-grid">
                      {awardCriteriaItems.map((item) => (
                        <article class="experience-detail-tech-card experience-detail-award-criteria-card">
                          <h3 class="experience-detail-tech-name" {...i18nText(item.ko.label, item.en.label)}>
                            {item.ko.label}
                          </h3>
                          {(item.ko.detail || item.en.detail) && (
                            <p class="experience-detail-tech-note" {...i18nText(item.ko.detail, item.en.detail)}>
                              {item.ko.detail}
                            </p>
                          )}
                        </article>
                      ))}
                    </div>
                  </div>
                </section>
              ) : (
                <section class:list={['experience-detail-section', isWorkExperience && 'experience-detail-work-section']}>
                  <span class="experience-detail-section-number">{String(index + 1).padStart(2, '0')}</span>
                  <div class="experience-detail-section-content">
                    <h2 class="experience-detail-section-label" {...i18nText(block.section.ko.label, block.section.en.label)}>{block.section.ko.label}</h2>
                    {
                      isWorkExperience && isWorkResponsibilitySection(block.section) && getWorkResponsibilityCards(block.section).length > 0 ? (
                        <div class="experience-work-card-list">
                          {getWorkResponsibilityCards(block.section).map((item) => (
                            <article class="experience-work-card">
                              {(item.ko.label || item.en.label) && (
                                <p class="experience-work-card-label" {...i18nText(item.ko.label, item.en.label)}>
                                  {item.ko.label}
                                </p>
                              )}
                              <p class="experience-work-card-body" {...i18nText(item.ko.body, item.en.body)}>
                                {item.ko.body}
                              </p>
                            </article>
                          ))}
                        </div>
                      ) : getSectionContentBlocks(block.section).length > 0 ? (
                        <div class="experience-detail-paragraph-list">
                          {getSectionContentBlocks(block.section).map((contentBlock) => (
                            contentBlock.type === 'list' ? (
                              <ul class="experience-detail-bullet-list">
                                {contentBlock.items.map((item) => (
                                  <li {...i18nText(item.ko, item.en)}>{item.ko}</li>
                                ))}
                              </ul>
                            ) : (
                              <p class="experience-detail-section-body" {...i18nText(contentBlock.ko, contentBlock.en)}>
                                {contentBlock.ko}
                              </p>
                            )
                          ))}
                        </div>
                      ) : null
                    }
                  </div>
                </section>
              )
            )}
            {
              hiddenStructuredDetailBlockCount > 0 && (
                <div class="experience-in-progress-placeholder">
                  <div class="experience-in-progress-notice" role="status">
                    <p
                      class="experience-in-progress-title"
                      {...i18nText('아직 진행 중인 경험입니다.', 'This experience is still in progress.')}
                    >
                      아직 진행 중인 경험입니다.
                    </p>
                    <p
                      class="experience-in-progress-description"
                      {...i18nText('종료 후 회고를 바탕으로 정리할 예정입니다.', 'I will organize it after it ends, based on a retrospective.')}
                    >
                      종료 후 회고를 바탕으로 정리할 예정입니다.
                    </p>
                  </div>
                  {Array.from({ length: Math.min(hiddenStructuredDetailBlockCount, 3) }).map((_, hiddenIndex) => (
                    <section class="experience-detail-section experience-in-progress-placeholder-section" aria-hidden="true">
                      <span class="experience-detail-section-number">
                        {String(visibleStructuredDetailBlocks.length + hiddenIndex + 1).padStart(2, '0')}
                      </span>
                      <div class="experience-detail-section-content">
                        <span class="experience-in-progress-placeholder-title" />
                        <span class="experience-in-progress-placeholder-line experience-in-progress-placeholder-line-long" />
                        <span class="experience-in-progress-placeholder-line" />
                        <span class="experience-in-progress-placeholder-line experience-in-progress-placeholder-line-short" />
                      </div>
                    </section>
                  ))}
                </div>
              )
            }
          </div>
        ) : (
          <div class="rich-text mx-auto max-w-3xl">
            <div data-i18n-content="ko">
              <KoContent />
            </div>
            <div data-i18n-content="en" hidden>
              <EnContent />
            </div>
          </div>
        )
      }
    </section>

    {
      relatedItems.length > 0 && (
        <section class="experience-related-panel">
          <div class="experience-related-heading">
            <p class="type-label-wide uppercase text-ink/40" {...i18nText('연결된 맥락', 'Connected Context')}>연결된 맥락</p>
            <p class="type-small text-ink/54" {...i18nText('이 경험과 함께 보면 좋은 기준점을 연결합니다.', 'Reference points connected to this experience.')}>
              이 경험과 함께 보면 좋은 기준점을 연결합니다.
            </p>
          </div>

          <div class="experience-related-list">
            {relatedItems.map((item) => (
              <div class="experience-related-card">
                {item.href ? (
                  <a href={item.href} class="experience-related-link">
                    <span class="experience-related-relation" {...localized(item.relationLabel)}>
                      {item.relationLabel.ko}
                    </span>
                    <span class="experience-related-title" {...localized(item.title)}>
                      {item.title.ko}
                    </span>
                    {
                      (item.periodLabel.ko || item.periodLabel.en) && (
                        <span class="experience-related-period" {...localized(item.periodLabel)}>
                          {item.periodLabel.ko}
                        </span>
                      )
                    }
                  </a>
                ) : (
                  <div class="experience-related-link">
                    <span class="experience-related-relation" {...localized(item.relationLabel)}>
                      {item.relationLabel.ko}
                    </span>
                    <span class="experience-related-title" {...localized(item.title)}>
                      {item.title.ko}
                    </span>
                    {
                      (item.periodLabel.ko || item.periodLabel.en) && (
                        <span class="experience-related-period" {...localized(item.periodLabel)}>
                          {item.periodLabel.ko}
                        </span>
                      )
                    }
                  </div>
                )}
                {(item.note.ko || item.note.en) && (
                  <p class="experience-related-note" {...i18nText(item.note.ko, item.note.en)}>
                    {item.note.ko}
                  </p>
                )}
              </div>
            ))}
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>
