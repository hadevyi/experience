---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMeta } from '../data/site';
import {
  experienceRelationLabels,
  formatExperiencePeriods,
  getExperienceDetailSections,
  getExperiencePairs,
  getLocalizedEntry,
  getLocalizedLink,
  getLocalizedListItem,
  getLocalizedText,
  resolveExperienceStatus,
  statusLabels
} from '../data/experienceArchive';
import {
  getProjectDomainLabel,
  getExperienceCategoryLabel,
  getExperienceTagLabel
} from '../data/experienceTaxonomy';

const i18nText = (ko: string, en: string) => ({
  'data-i18n-ko': ko,
  'data-i18n-en': en
});

const i18nAttr = (attr: string, ko: string, en: string) => ({
  'data-i18n-attr': attr,
  'data-i18n-ko': ko,
  'data-i18n-en': en
});

const localized = (value: { ko: string; en: string }) => i18nText(value.ko, value.en);
const tagAriaLabel = (tag: { ko: string; en: string; description: { ko: string; en: string } }) =>
  i18nAttr('aria-label', `${tag.ko}: ${tag.description.ko}`, `${tag.en}: ${tag.description.en}`);

export async function getStaticPaths() {
  const experiences = getExperiencePairs(await getCollection('experiences'));

  return experiences.map((entry) => ({
    params: { slug: entry.number },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const koContent = await render(getLocalizedEntry(entry, 'ko'));
const enContent = await render(getLocalizedEntry(entry, 'en'));
const KoContent = koContent.Content;
const EnContent = enContent.Content;
const allExperiencePairs = getExperiencePairs(await getCollection('experiences'));
const experienceByNumber = new Map(allExperiencePairs.map((item) => [item.number, item]));
const title = getLocalizedText(entry, 'title');
const summary = getLocalizedText(entry, 'summary');
const oneLine = getLocalizedText(entry, 'oneLine');
const shouldShowSummary =
  summary.ko.trim().length > 0 &&
  summary.en.trim().length > 0 &&
  (summary.ko.trim() !== oneLine.ko.trim() || summary.en.trim() !== oneLine.en.trim());
const organization = getLocalizedText(entry, 'organization');
const categoryLabel = getExperienceCategoryLabel(entry.meta.category);
const experienceTagLabels = (entry.meta.experienceTags ?? []).map((tag) => getExperienceTagLabel(tag));
const projectDomainLabels = (entry.meta.projectDomains ?? []).map((domain) => getProjectDomainLabel(domain));
const periodLabel = {
  ko: formatExperiencePeriods(entry.meta, 'ko'),
  en: formatExperiencePeriods(entry.meta, 'en')
};
const statusLabel = statusLabels[resolveExperienceStatus(entry.meta.status)];
const koProject = entry.ko.data.project;
const enProject = (entry.en ?? entry.ko).data.project ?? koProject;
const projectTechCategoryLabels = {
  language: {
    ko: '언어',
    en: 'Language'
  },
  framework: {
    ko: '프레임워크',
    en: 'Framework'
  },
  database: {
    ko: '데이터베이스',
    en: 'Database'
  },
  tool: {
    ko: '도구',
    en: 'Tool'
  },
  environment: {
    ko: '개발환경',
    en: 'Environment'
  },
  platform: {
    ko: '플랫폼',
    en: 'Platform'
  },
  other: {
    ko: '기타',
    en: 'Other'
  }
} as const;
const projectTechStackItems = (koProject?.techStack ?? []).map((item, index) => {
  const enItem = enProject?.techStack?.[index] ?? item;
  const category = item.category ?? 'other';

  return {
    category,
    categoryLabel: projectTechCategoryLabels[category],
    ko: item,
    en: enItem
  };
});
const hasProjectTechStack = entry.meta.category === 'project' && projectTechStackItems.length > 0;
const formatProjectDomainValue = (language: 'ko' | 'en') =>
  projectDomainLabels.map((item) => item[language]).filter(Boolean).join(', ');
const formatProjectTeamSize = (language: 'ko' | 'en') => {
  if (!entry.meta.teamSize) {
    return '';
  }

  if (language === 'ko') {
    return `${entry.meta.teamSize}인`;
  }

  return entry.meta.teamSize === 1 ? '1 person' : `${entry.meta.teamSize} people`;
};
const projectInfoRows =
  entry.meta.category === 'project' && koProject
    ? [
        {
          label: { ko: '도메인', en: 'Domain' },
          value: {
            ko: formatProjectDomainValue('ko'),
            en: formatProjectDomainValue('en')
          }
        },
        {
          label: { ko: '소속/주최', en: 'Host' },
          value: { ko: koProject.host, en: enProject?.host || koProject.host }
        },
        {
          label: { ko: '참여 인원', en: 'Team Size' },
          value: { ko: formatProjectTeamSize('ko'), en: formatProjectTeamSize('en') }
        },
        {
          label: { ko: '직책/역할', en: 'Position / Role' },
          value: { ko: koProject.position, en: enProject?.position || koProject.position }
        },
        {
          label: { ko: '배포/실행', en: 'Run / Deployment' },
          value: { ko: koProject.deployment, en: enProject?.deployment || koProject.deployment }
        }
      ].filter((item) => item.value.ko.trim().length > 0 || item.value.en.trim().length > 0)
    : [];
const representativeImage = entry.meta.representativeImage;
const representativeImageAlt = {
  ko: representativeImage?.alt?.ko ?? title.ko,
  en: representativeImage?.alt?.en ?? title.en
};
const structuredSections = getExperienceDetailSections(entry);
const structuredDetailBlocks = structuredSections.flatMap((section, index) => {
  const blocks = [{ type: 'section', section }] as Array<
    | { type: 'section'; section: (typeof structuredSections)[number] }
    | { type: 'techStack' }
  >;

  if (index === 0 && hasProjectTechStack) {
    blocks.push({ type: 'techStack' });
  }

  return blocks;
});
const highlights = entry.ko.data.highlights.map((_, index) =>
  getLocalizedListItem(entry, 'highlights', index)
).filter(
  (highlight) => highlight.ko.trim().length > 0 || highlight.en.trim().length > 0
);
const links = entry.ko.data.links.map((_, index) =>
  getLocalizedLink(entry, index)
);
const relatedItems = (entry.meta.related ?? []).map((item) => {
  const relatedEntry = experienceByNumber.get(item.number);
  const relationLabel = experienceRelationLabels[item.relation ?? 'related'];
  const relatedTitle = relatedEntry
    ? getLocalizedText(relatedEntry, 'title')
    : {
        ko: item.number,
        en: item.number
      };
  const relatedPeriodLabel = relatedEntry
    ? {
        ko: formatExperiencePeriods(relatedEntry.meta, 'ko'),
        en: formatExperiencePeriods(relatedEntry.meta, 'en')
      }
    : {
        ko: '',
        en: ''
      };
  const note = {
    ko: item.note?.ko ?? '',
    en: item.note?.en ?? item.note?.ko ?? ''
  };

  return {
    ...item,
    href: relatedEntry ? `${siteMeta.rootPath}${relatedEntry.number}/` : '',
    relationLabel,
    title: relatedTitle,
    periodLabel: relatedPeriodLabel,
    note
  };
}).sort((a, b) => Number(a.number) - Number(b.number));
---

<BaseLayout
  title={title.ko}
  description={summary.ko}
  showHeader={false}
  mainClass="experience-detail-main mx-auto w-full max-w-[62rem] px-5 pb-24 pt-5 sm:px-8 lg:px-10"
>
  <article class="experience-detail-page">
    <nav class="experience-detail-nav" {...i18nAttr('aria-label', '경험 상세 탐색', 'Experience detail navigation')}>
      <a href={siteMeta.rootPath} class="experience-back-link">
        <span aria-hidden="true">←</span>
        <span {...i18nText('목록으로 돌아가기', 'Back to list')}>목록으로 돌아가기</span>
      </a>
    </nav>

    <section class="experience-detail-hero">
      <div class="experience-detail-hero-main">
        <p class="experience-detail-kicker">
          <span>{entry.meta.number}</span>
          <span aria-hidden="true">/</span>
          <span {...localized(categoryLabel)}>{categoryLabel.ko}</span>
        </p>
        <h1 class="experience-detail-title" {...localized(title)}>
          {title.ko}
        </h1>
        {
          (oneLine.ko || oneLine.en) && (
            <p class="experience-detail-one-line" {...localized(oneLine)}>
              {oneLine.ko}
            </p>
          )
        }
        {
          shouldShowSummary && (
            <p class="experience-detail-summary" {...localized(summary)}>
              {summary.ko}
            </p>
          )
        }

        {
          links.length > 0 && (
            <div class="experience-detail-hero-links" {...i18nAttr('aria-label', '공개 링크', 'Public links')}>
              <div class="experience-detail-hero-link-list">
                {links.map((link) => (
                  <a href={link.ko.url} class="experience-detail-hero-link" rel="noreferrer">
                    <span {...i18nText(link.ko.label, link.en.label)}>{link.ko.label}</span>
                    <span aria-hidden="true">↗</span>
                  </a>
                ))}
              </div>
            </div>
          )
        }

        {
          highlights.length > 0 && (
            <ul class="experience-detail-highlight-list">
              {highlights.map((highlight) => (
                <li>
                  <span aria-hidden="true" />
                  <span {...i18nText(highlight.ko, highlight.en)}>{highlight.ko}</span>
                </li>
              ))}
            </ul>
          )
        }
      </div>

      <aside class="experience-detail-record-card" {...i18nAttr('aria-label', '경험 기본 정보', 'Experience information')}>
        {
          representativeImage && (
            <figure class="experience-detail-image-card">
              <img src={representativeImage.src} {...i18nAttr('alt', representativeImageAlt.ko, representativeImageAlt.en)} />
            </figure>
          )
        }

        <dl class="experience-detail-info">
          <div>
            <dt {...i18nText('기간', 'Period')}>기간</dt>
            <dd {...localized(periodLabel)}>{periodLabel.ko}</dd>
          </div>
          {
            projectInfoRows.length > 0 ? (
              projectInfoRows.map((item) => (
                <div>
                  <dt {...localized(item.label)}>{item.label.ko}</dt>
                  <dd {...localized(item.value)}>{item.value.ko}</dd>
                </div>
              ))
            ) : (
              <div>
                <dt {...i18nText('기관', 'Organization')}>기관</dt>
                <dd {...localized(organization)}>{organization.ko}</dd>
              </div>
            )
          }
          <div>
            <dt {...i18nText('상태', 'Status')}>상태</dt>
            <dd {...i18nText(statusLabel.ko, statusLabel.en)}>{statusLabel.ko}</dd>
          </div>
        </dl>

        <div class="experience-detail-chip-group">
          {
            experienceTagLabels.map((tag) => (
              <span class="chip experience-tag-chip" {...tagAriaLabel(tag)}>
                <span {...localized(tag)}>{tag.ko}</span>
                <span class="experience-tag-tooltip" aria-hidden="true">
                  <span {...localized(tag.description)}>{tag.description.ko}</span>
                </span>
              </span>
            ))
          }
        </div>
      </aside>
    </section>

    <section class="experience-detail-body">
      {
        structuredSections.length > 0 ? (
          <div class="experience-detail-section-list">
            {structuredDetailBlocks.map((block, index) =>
              block.type === 'techStack' ? (
                <section class="experience-detail-section experience-detail-tech-section">
                  <span class="experience-detail-section-number">{String(index + 1).padStart(2, '0')}</span>
                  <div class="experience-detail-section-content experience-detail-tech-content">
                    <h2 class="experience-detail-section-label" {...i18nText('기술 스택', 'Tech Stack')}>기술 스택</h2>
                    <div class="experience-detail-tech-grid">
                      {projectTechStackItems.map((item) => (
                        <article class="experience-detail-tech-card">
                          <p class="experience-detail-tech-category" {...localized(item.categoryLabel)}>
                            {item.categoryLabel.ko}
                          </p>
                          <h3 class="experience-detail-tech-name" {...i18nText(item.ko.name, item.en.name)}>
                            {item.ko.name}
                          </h3>
                          {(item.ko.version || item.en.version) && (
                            <p class="experience-detail-tech-version" {...i18nText(item.ko.version, item.en.version)}>
                              {item.ko.version}
                            </p>
                          )}
                          {(item.ko.note || item.en.note) && (
                            <p class="experience-detail-tech-note" {...i18nText(item.ko.note, item.en.note)}>
                              {item.ko.note}
                            </p>
                          )}
                        </article>
                      ))}
                    </div>
                  </div>
                </section>
              ) : (
                <section class="experience-detail-section">
                  <span class="experience-detail-section-number">{String(index + 1).padStart(2, '0')}</span>
                  <div class="experience-detail-section-content">
                    <h2 class="experience-detail-section-label" {...i18nText(block.section.ko.label, block.section.en.label)}>{block.section.ko.label}</h2>
                    <p class="experience-detail-section-body" {...i18nText(block.section.ko.body, block.section.en.body)}>{block.section.ko.body}</p>
                  </div>
                </section>
              )
            )}
          </div>
        ) : (
          <div class="rich-text mx-auto max-w-3xl">
            <div data-i18n-content="ko">
              <KoContent />
            </div>
            <div data-i18n-content="en" hidden>
              <EnContent />
            </div>
          </div>
        )
      }
    </section>

    {
      relatedItems.length > 0 && (
        <section class="experience-related-panel">
          <div class="experience-related-heading">
            <p class="type-label-wide uppercase text-ink/40" {...i18nText('연결된 맥락', 'Connected Context')}>연결된 맥락</p>
            <p class="type-small text-ink/54" {...i18nText('이 경험과 함께 보면 좋은 기준점을 연결합니다.', 'Reference points connected to this experience.')}>
              이 경험과 함께 보면 좋은 기준점을 연결합니다.
            </p>
          </div>

          <div class="experience-related-list">
            {relatedItems.map((item) => (
              <div class="experience-related-card">
                {item.href ? (
                  <a href={item.href} class="experience-related-link">
                    <span class="experience-related-relation" {...localized(item.relationLabel)}>
                      {item.relationLabel.ko}
                    </span>
                    <span class="experience-related-title" {...localized(item.title)}>
                      {item.title.ko}
                    </span>
                    {
                      (item.periodLabel.ko || item.periodLabel.en) && (
                        <span class="experience-related-period" {...localized(item.periodLabel)}>
                          {item.periodLabel.ko}
                        </span>
                      )
                    }
                  </a>
                ) : (
                  <div class="experience-related-link">
                    <span class="experience-related-relation" {...localized(item.relationLabel)}>
                      {item.relationLabel.ko}
                    </span>
                    <span class="experience-related-title" {...localized(item.title)}>
                      {item.title.ko}
                    </span>
                    {
                      (item.periodLabel.ko || item.periodLabel.en) && (
                        <span class="experience-related-period" {...localized(item.periodLabel)}>
                          {item.periodLabel.ko}
                        </span>
                      )
                    }
                  </div>
                )}
                {(item.note.ko || item.note.en) && (
                  <p class="experience-related-note" {...i18nText(item.note.ko, item.note.en)}>
                    {item.note.ko}
                  </p>
                )}
              </div>
            ))}
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>
