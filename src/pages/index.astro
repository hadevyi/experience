---
import { getCollection } from 'astro:content';
import ContentCard from '../components/ContentCard.astro';
import PageIntro from '../components/PageIntro.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const experiences = (await getCollection('experiences')).sort((a, b) => a.data.order - b.data.order);
const focusOptions = [...new Set(experiences.flatMap((entry) => entry.data.focus))];
---

<BaseLayout>
  <div class="space-y-12">
    <PageIntro
      eyebrow="Experience"
      title="시간의 흐름과 작업 기준을 기록하는 경험 정리"
      description="이 페이지도 기존 디자인을 모두 걷어낸 상태입니다. 검색과 초점 필터, 그리고 기록 목록만 남겨두고 이후 화면은 다시 같이 정리합니다."
    />

    <section class="surface-card p-6" data-archive-root="experience">
      <h2 class="type-section-title text-ink">
        검색과 초점
      </h2>

      <label class="mt-5 block">
        <span class="sr-only">경험 기록 검색</span>
        <input
          type="search"
          class="archive-input"
          placeholder="제목, 요약, 조직, 초점 키워드 검색"
          data-archive-search
        />
      </label>

      <div class="mt-4 flex flex-wrap gap-2">
        <button
          type="button"
          class="filter-chip-button filter-chip-button-active"
          data-filter-button
          data-filter-value="all"
        >
          전체
        </button>
        {
          focusOptions.map((focus) => (
            <button
              type="button"
              class="filter-chip-button"
              data-filter-button
              data-filter-value={focus}
            >
              {focus}
            </button>
          ))
        }
      </div>
    </section>

    <section class="space-y-4">
      <h2 class="type-section-title text-ink">
        경험 기록
      </h2>
      <div class="grid gap-4" data-archive-list>
        {
          experiences.map((entry) => (
            <div
              data-archive-item
              data-search={`${entry.data.title} ${entry.data.summary} ${entry.data.organization} ${entry.data.period} ${entry.data.focus.join(' ')}`.toLowerCase()}
              data-tags={entry.data.focus.join('|')}
            >
              <ContentCard
                href={`/experience/${entry.id}/`}
                title={entry.data.title}
                description={entry.data.summary}
                meta={`${entry.data.organization} · ${entry.data.period}`}
                tags={entry.data.focus}
              />
            </div>
          ))
        }
      </div>

      <p class="type-small text-ink/58" data-archive-empty hidden>
        현재 조건에 맞는 경험 기록이 없습니다.
      </p>
    </section>
  </div>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-archive-root="experience"]');
      if (!root) return;

      const input = root.querySelector('[data-archive-search]');
      const items = Array.from(document.querySelectorAll('[data-archive-item]'));
      const buttons = Array.from(root.querySelectorAll('[data-filter-button]'));
      const empty = document.querySelector('[data-archive-empty]');

      let activeFilter = 'all';

      const apply = () => {
        const query = input instanceof HTMLInputElement ? input.value.trim().toLowerCase() : '';
        let visibleCount = 0;

        items.forEach((item) => {
          const searchValue = (item.getAttribute('data-search') || '').toLowerCase();
          const tags = (item.getAttribute('data-tags') || '').split('|').filter(Boolean);
          const matchesQuery = !query || searchValue.includes(query);
          const matchesFilter = activeFilter === 'all' || tags.includes(activeFilter);
          const isVisible = matchesQuery && matchesFilter;

          item.toggleAttribute('hidden', !isVisible);
          if (isVisible) visibleCount += 1;
        });

        if (empty instanceof HTMLElement) {
          empty.hidden = visibleCount !== 0;
        }
      };

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          activeFilter = button.getAttribute('data-filter-value') || 'all';

          buttons.forEach((candidate) => {
            candidate.classList.toggle('filter-chip-button-active', candidate === button);
          });

          apply();
        });
      });

      if (input instanceof HTMLInputElement) {
        input.addEventListener('input', apply);
      }

      apply();
    })();
  </script>
</BaseLayout>
