  <script is:inline>
    (() => {
      const root = document.querySelector('[data-experience-archive]');
      if (!root) return;

      const search = root.querySelector('[data-archive-search]');
      const mobileSearch = root.querySelector('[data-mobile-archive-search]');
      const list = root.querySelector('[data-archive-list]');
      const items = Array.from(root.querySelectorAll('.archive-experience-item'));
      const buttons = Array.from(root.querySelectorAll('[data-filter-group]'));
      const dateTriggers = Array.from(root.querySelectorAll('[data-date-trigger]'));
      const dateDisplays = Array.from(root.querySelectorAll('[data-date-display]'));
      const calendarPopovers = Array.from(root.querySelectorAll('[data-calendar-popover]'));
      const empty = root.querySelector('[data-archive-empty]');
      const pagination = root.querySelector('[data-archive-pagination]');
      const paginationCount = root.querySelector('[data-archive-count]');
      const resultCount = root.querySelector('[data-archive-result-count]');
      const totalCount = root.querySelector('[data-archive-total-count]');
      const loadMoreButton = root.querySelector('[data-archive-load-more]');
      const showAllButton = root.querySelector('[data-archive-show-all]');
      const sortByTrigger = root.querySelector('[data-archive-sort-by-trigger]');
      const sortByLabel = root.querySelector('[data-archive-sort-by-label]');
      const sortByMenu = root.querySelector('[data-archive-sort-by-menu]');
      const sortByOptions = Array.from(root.querySelectorAll('[data-archive-sort-by-option]'));
      const archiveContent = root.querySelector('.experience-archive-content');
      const listHeader = root.querySelector('.experience-list-header');
      const listHeaderSentinel = root.querySelector('[data-list-header-sentinel]');
      const railToggle = root.querySelector('[data-rail-toggle]');
      const railToggleLabel = root.querySelector('[data-rail-toggle-label]');
      const railToggleIcon = root.querySelector('[data-rail-toggle-icon]');
      const categoryToggle = root.querySelector('[data-category-toggle]');
      const categoryToggleLabel = root.querySelector('[data-category-toggle-label]');
      const categoryToggleIcon = root.querySelector('[data-category-toggle-icon]');
      const tagToggle = root.querySelector('[data-tag-toggle]');
      const tagToggleLabel = root.querySelector('[data-tag-toggle-label]');
      const tagToggleIcon = root.querySelector('[data-tag-toggle-icon]');
      const projectFilterToggle = root.querySelector('[data-project-filter-toggle]');
      const projectFilterToggleLabel = root.querySelector('[data-project-filter-toggle-label]');
      const projectFilterToggleIcon = root.querySelector('[data-project-filter-toggle-icon]');
      const tagHintTitle = root.querySelector('[data-tag-hint-title]');
      const tagHintBody = root.querySelector('[data-tag-hint-body]');
      const tagButtons = Array.from(root.querySelectorAll('[data-filter-group="tag"]'));
      const mobileFilterOpenButton = root.querySelector('[data-mobile-filter-open-button]');
      const mobileFilterCloseButton = root.querySelector('[data-mobile-filter-close]');
      const mobileFilterBackdrop = root.querySelector('[data-mobile-filter-backdrop]');
      const mobileFilterMedia = window.matchMedia('(max-width: 720px)');

      const state = {
        periodStart: '',
        periodEnd: '',
        status: 'all',
        category: [],
        tag: [],
        projectDomain: [],
        techTag: [],
        sortBy: 'number',
        sortDirection: 'desc',
        view: 'card',
        grouping: 'none',
        visibleLimit: 9
      };
      const visiblePageSize = 9;
      const sortByLabels = {
        number: { ko: '번호', en: 'Number' },
        organization: { ko: '기관', en: 'Organization' },
        category: { ko: '분류', en: 'Category' }
      };
      const categoryDescriptions = {
        project: {
          ko: '직접 만든 서비스, 웹사이트, 개발 산출물',
          en: 'Services, websites, and development deliverables I built.'
        },
        affiliation: {
          ko: '학교, 회사, 커뮤니티처럼 오래 머문 기반',
          en: 'Long-running foundations such as schools, companies, and communities.'
        },
        'work-experience': {
          ko: '회사 안에서 맡았던 실무와 책임 범위',
          en: 'Practical work and responsibilities carried at work.'
        },
        'event-operation': {
          ko: '행사, 프로그램, 모임을 준비하고 굴린 일',
          en: 'Events, programs, and gatherings I prepared and ran.'
        },
        'learning-growth': {
          ko: '공부하며 기준을 세우고 시야를 넓힌 흐름',
          en: 'Learning paths that shaped standards and perspective.'
        },
        certification: {
          ko: '시험, 자격, 인증으로 확인한 역량',
          en: 'Capability validated through tests, credentials, and certifications.'
        },
        'teaching-mentoring': {
          ko: '알고 있는 것과 시행착오를 나눈 자리',
          en: 'Moments where I shared knowledge and lessons learned.'
        },
        community: {
          ko: '사람들과 함께 만든 참여, 운영, 연결',
          en: 'Participation, operation, and connection built with others.'
        },
        'award-scholarship': {
          ko: '성과, 태도, 가능성을 인정받은 결과',
          en: 'Recognition of outcomes, attitude, or potential.'
        },
        'media-interview': {
          ko: '글, 인터뷰, 발표로 밖에 꺼낸 이야기',
          en: 'Stories shared outward through writing, interviews, and talks.'
        }
      };
      const categoryImages = {
        project: '/experience/images/groups/project.jpg',
        affiliation: '/experience/images/groups/affiliation.jpg',
        'work-experience': '/experience/images/groups/work-experience.jpg',
        'event-operation': '/experience/images/groups/event-operation.jpg',
        'learning-growth': '/experience/images/groups/learning-growth.jpg',
        certification: '/experience/images/groups/certification.jpg',
        'teaching-mentoring': '/experience/images/groups/teaching-mentoring.jpg',
        community: '/experience/images/groups/community.jpg',
        'award-scholarship': '/experience/images/groups/award-scholarship.jpg',
        'media-interview': '/experience/images/groups/media-interview.jpg'
      };

      const updateListHeaderState = () => {
        const scrollTop = archiveContent ? archiveContent.scrollTop : window.scrollY;
        const headerTop = listHeader instanceof HTMLElement ? listHeader.getBoundingClientRect().top : 0;
        listHeader?.classList.toggle('experience-list-header-stuck', scrollTop > 8 && headerTop <= 1);
      };
      const observeListHeaderState = () => {
        if (
          !(listHeader instanceof HTMLElement) ||
          !(listHeaderSentinel instanceof HTMLElement) ||
          typeof IntersectionObserver === 'undefined'
        ) {
          return;
        }

        const observer = new IntersectionObserver(
          ([entry]) => {
            listHeader.classList.toggle('experience-list-header-stuck', !entry.isIntersecting);
          },
          {
            root: archiveContent instanceof HTMLElement ? archiveContent : null,
            threshold: 0
          }
        );

        observer.observe(listHeaderSentinel);
      };
      const syncListHeaderState = () => {
        updateListHeaderState();
        window.requestAnimationFrame(syncListHeaderState);
      };

      const setSortByMenuOpen = (isOpen) => {
        if (!(sortByMenu instanceof HTMLElement) || !(sortByTrigger instanceof HTMLButtonElement)) return;
        sortByMenu.hidden = !isOpen;
        sortByTrigger.setAttribute('aria-expanded', String(isOpen));
      };

      const updateSortByControl = () => {
        const label = sortByLabels[state.sortBy] ?? sortByLabels.number;
        if (sortByLabel instanceof HTMLElement) {
          sortByLabel.textContent = isEnglish() ? label.en : label.ko;
        }

        sortByOptions.forEach((option) => {
          const value = option.getAttribute('data-archive-sort-by-option');
          const isActive = value === state.sortBy;
          option.classList.toggle('experience-toolbar-select-option-active', isActive);
          option.setAttribute('aria-checked', String(isActive));
        });
      };

      const today = new Date();
      let activeCalendar = '';
      const calendarState = {
        periodStart: new Date(today.getFullYear(), today.getMonth(), 1),
        periodEnd: new Date(today.getFullYear(), today.getMonth(), 1)
      };

      const isEnglish = () => document.documentElement.lang === 'en';
      const setMobileFilterOpen = (isOpen) => {
        root.setAttribute('data-mobile-filter-open', String(isOpen));
        document.documentElement.classList.toggle('experience-mobile-filter-lock', isOpen);

        if (mobileFilterOpenButton instanceof HTMLButtonElement) {
          mobileFilterOpenButton.setAttribute('aria-expanded', String(isOpen));
        }

        if (mobileFilterBackdrop instanceof HTMLButtonElement) {
          mobileFilterBackdrop.hidden = !isOpen;
        }
      };
      const syncSearchInputs = (value, source) => {
        if (search instanceof HTMLInputElement && source !== search) search.value = value;
        if (mobileSearch instanceof HTMLInputElement && source !== mobileSearch) mobileSearch.value = value;
      };
      const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
      const toMonthValue = (date) =>
        `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
      const parseMonthValue = (value) => {
        const [year, month] = value.split('-').map(Number);
        return new Date(year, month - 1, 1);
      };
      const toMonthRangeEnd = (value) => {
        const [year, month] = value.split('-').map(Number);
        const lastDay = new Date(year, month, 0).getDate();
        return `${year}-${String(month).padStart(2, '0')}-${String(lastDay).padStart(2, '0')}`;
      };
      const formatDisplayDate = (value) => {
        if (!value) return isEnglish() ? 'Year. Month.' : '연도. 월.';
        const [year, month] = value.split('-');
        return `${year}. ${month}.`;
      };
      const formatCalendarTitle = (date) => {
        const year = date.getFullYear();
        return isEnglish() ? `${year}` : `${year}년`;
      };
      const getPopover = (field) =>
        calendarPopovers.find((popover) => popover.getAttribute('data-calendar-popover') === field);
      const getTrigger = (field) =>
        dateTriggers.find((trigger) => trigger.getAttribute('data-date-trigger') === field);

      const updateDateDisplays = () => {
        dateDisplays.forEach((display) => {
          const field = display.getAttribute('data-date-display');
          if (!field || !(field in state)) return;

          const value = state[field];
          display.textContent = formatDisplayDate(value);
          display.classList.toggle('experience-date-placeholder', !value);
        });
      };

      const setCalendarOpen = (field, isOpen) => {
        const popover = getPopover(field);
        const trigger = getTrigger(field);
        if (!(popover instanceof HTMLElement) || !(trigger instanceof HTMLButtonElement)) return;

        popover.hidden = !isOpen;
        trigger.setAttribute('aria-expanded', String(isOpen));
        trigger.classList.toggle('experience-date-trigger-active', isOpen);
      };

      const closeCalendars = () => {
        activeCalendar = '';
        calendarPopovers.forEach((popover) => {
          const field = popover.getAttribute('data-calendar-popover');
          if (field) setCalendarOpen(field, false);
        });
      };

      const renderCalendar = (field) => {
        const popover = getPopover(field);
        const yearDate = calendarState[field];
        if (!(popover instanceof HTMLElement) || !(yearDate instanceof Date)) return;

        const year = yearDate.getFullYear();
        const selectedValue = state[field];
        const todayValue = toMonthValue(today);
        const months = Array.from({ length: 12 }, (_, index) => {
          const value = `${year}-${String(index + 1).padStart(2, '0')}`;
          const label = isEnglish() ? monthNames[index] : `${index + 1}월`;
          const classes = [
            'experience-calendar-month',
            value === todayValue ? 'experience-calendar-month-today' : '',
            value === selectedValue ? 'experience-calendar-month-selected' : ''
          ].filter(Boolean).join(' ');

          return `<button type="button" class="${classes}" data-calendar-month="${value}">${label}</button>`;
        }).join('');

        popover.innerHTML = `
          <div class="experience-calendar-card" role="dialog" aria-label="${isEnglish() ? 'Month picker' : '월 선택'}">
            <div class="experience-calendar-head">
              <button type="button" class="experience-calendar-nav" data-calendar-action="prev" aria-label="${isEnglish() ? 'Previous year' : '이전 연도'}">‹</button>
              <strong>${formatCalendarTitle(yearDate)}</strong>
              <button type="button" class="experience-calendar-nav" data-calendar-action="next" aria-label="${isEnglish() ? 'Next year' : '다음 연도'}">›</button>
            </div>
            <div class="experience-calendar-months">${months}</div>
            <div class="experience-calendar-foot">
              <button type="button" data-calendar-action="clear">${isEnglish() ? 'Clear' : '삭제'}</button>
              <button type="button" data-calendar-action="today">${isEnglish() ? 'This month' : '이번 달'}</button>
            </div>
          </div>
        `;
      };

      const openCalendar = (field) => {
        closeCalendars();

        if (state[field]) {
          const selected = parseMonthValue(state[field]);
          calendarState[field] = new Date(selected.getFullYear(), selected.getMonth(), 1);
        }

        activeCalendar = field;
        renderCalendar(field);
        setCalendarOpen(field, true);
      };

      const setDateValue = (field, value) => {
        state[field] = value;
        resetVisibleLimit();
        updateDateDisplays();
        apply();
      };

      const setSidebarCollapsed = (isCollapsed) => {
        const label = isCollapsed
          ? { ko: '필터 열기', en: 'Show filters' }
          : { ko: '필터 접기', en: 'Hide filters' };
        const ariaLabel = isCollapsed
          ? { ko: '필터 펼치기', en: 'Show filters' }
          : { ko: '필터 접기', en: 'Hide filters' };

        root.setAttribute('data-sidebar-collapsed', String(isCollapsed));

        if (railToggle instanceof HTMLButtonElement) {
          railToggle.setAttribute('aria-expanded', String(!isCollapsed));
          railToggle.dataset.i18nKo = ariaLabel.ko;
          railToggle.dataset.i18nEn = ariaLabel.en;
          railToggle.dataset.i18nAttr = 'aria-label';
          railToggle.setAttribute('aria-label', isEnglish() ? ariaLabel.en : ariaLabel.ko);
        }

        if (railToggleLabel instanceof HTMLElement) {
          railToggleLabel.dataset.i18nKo = label.ko;
          railToggleLabel.dataset.i18nEn = label.en;
          railToggleLabel.textContent = isEnglish() ? label.en : label.ko;
        }

        if (railToggleIcon instanceof HTMLElement) {
          railToggleIcon.textContent = isCollapsed ? '→' : '←';
        }
      };

      const setCategoryCollapsed = (isCollapsed) => {
        const label = isCollapsed
          ? { ko: '펼치기', en: 'Show' }
          : { ko: '접기', en: 'Hide' };
        const ariaLabel = isCollapsed
          ? { ko: '분류 펼치기', en: 'Show category filters' }
          : { ko: '분류 접기', en: 'Hide category filters' };

        root.setAttribute('data-category-collapsed', String(isCollapsed));

        if (categoryToggle instanceof HTMLButtonElement) {
          categoryToggle.setAttribute('aria-expanded', String(!isCollapsed));
          categoryToggle.dataset.i18nKo = ariaLabel.ko;
          categoryToggle.dataset.i18nEn = ariaLabel.en;
          categoryToggle.dataset.i18nAttr = 'aria-label';
          categoryToggle.setAttribute('aria-label', isEnglish() ? ariaLabel.en : ariaLabel.ko);
        }

        if (categoryToggleLabel instanceof HTMLElement) {
          categoryToggleLabel.dataset.i18nKo = label.ko;
          categoryToggleLabel.dataset.i18nEn = label.en;
          categoryToggleLabel.textContent = isEnglish() ? label.en : label.ko;
        }

        if (categoryToggleIcon instanceof HTMLElement) {
          categoryToggleIcon.textContent = isCollapsed ? '⌄' : '⌃';
        }
      };

      const setTagCollapsed = (isCollapsed) => {
        const label = isCollapsed
          ? { ko: '펼치기', en: 'Show' }
          : { ko: '접기', en: 'Hide' };
        const ariaLabel = isCollapsed
          ? { ko: '경험태그 펼치기', en: 'Show tag filters' }
          : { ko: '경험태그 접기', en: 'Hide tag filters' };

        root.setAttribute('data-tag-collapsed', String(isCollapsed));

        if (tagToggle instanceof HTMLButtonElement) {
          tagToggle.setAttribute('aria-expanded', String(!isCollapsed));
          tagToggle.dataset.i18nKo = ariaLabel.ko;
          tagToggle.dataset.i18nEn = ariaLabel.en;
          tagToggle.dataset.i18nAttr = 'aria-label';
          tagToggle.setAttribute('aria-label', isEnglish() ? ariaLabel.en : ariaLabel.ko);
        }

        if (tagToggleLabel instanceof HTMLElement) {
          tagToggleLabel.dataset.i18nKo = label.ko;
          tagToggleLabel.dataset.i18nEn = label.en;
          tagToggleLabel.textContent = isEnglish() ? label.en : label.ko;
        }

        if (tagToggleIcon instanceof HTMLElement) {
          tagToggleIcon.textContent = isCollapsed ? '⌄' : '⌃';
        }
      };

      const setProjectFilterCollapsed = (isCollapsed) => {
        const label = isCollapsed
          ? { ko: '펼치기', en: 'Show' }
          : { ko: '접기', en: 'Hide' };
        const ariaLabel = isCollapsed
          ? { ko: '프로젝트 필터 펼치기', en: 'Show project filters' }
          : { ko: '프로젝트 필터 접기', en: 'Hide project filters' };

        root.setAttribute('data-project-filter-collapsed', String(isCollapsed));

        if (projectFilterToggle instanceof HTMLButtonElement) {
          projectFilterToggle.setAttribute('aria-expanded', String(!isCollapsed));
          projectFilterToggle.dataset.i18nKo = ariaLabel.ko;
          projectFilterToggle.dataset.i18nEn = ariaLabel.en;
          projectFilterToggle.dataset.i18nAttr = 'aria-label';
          projectFilterToggle.setAttribute('aria-label', isEnglish() ? ariaLabel.en : ariaLabel.ko);
        }

        if (projectFilterToggleLabel instanceof HTMLElement) {
          projectFilterToggleLabel.dataset.i18nKo = label.ko;
          projectFilterToggleLabel.dataset.i18nEn = label.en;
          projectFilterToggleLabel.textContent = isEnglish() ? label.en : label.ko;
        }

        if (projectFilterToggleIcon instanceof HTMLElement) {
          projectFilterToggleIcon.textContent = isCollapsed ? '⌄' : '⌃';
        }
      };

      const resetTagHint = () => {
        const selectedTags = Array.isArray(state.tag) ? state.tag : [];
        const activeTagButton =
          selectedTags.length === 1
            ? tagButtons.find(
                (button) =>
                  button instanceof HTMLElement &&
                  button.getAttribute('data-filter-value') === selectedTags[0]
              )
            : null;

        if (activeTagButton instanceof HTMLElement) {
          setTagHint(activeTagButton);
          return;
        }

        if (tagHintTitle instanceof HTMLElement) {
          const nextTitle = selectedTags.length > 1
            ? isEnglish()
              ? `${selectedTags.length} tags selected`
              : `${selectedTags.length}개 태그 선택`
            : isEnglish()
              ? tagHintTitle.dataset.i18nEn
              : tagHintTitle.dataset.i18nKo;
          if (nextTitle) tagHintTitle.textContent = nextTitle;
        }

        if (tagHintBody instanceof HTMLElement) {
          const nextBody = selectedTags.length > 1
            ? isEnglish()
              ? 'Experiences with any selected tag will be shown.'
              : '선택한 태그 중 하나라도 포함된 경험을 보여줍니다.'
            : isEnglish()
              ? tagHintBody.dataset.i18nEn
              : tagHintBody.dataset.i18nKo;
          if (nextBody) tagHintBody.textContent = nextBody;
        }
      };

      const setTagHint = (button) => {
        if (!(button instanceof HTMLElement)) return;

        const nextTitle = isEnglish()
          ? button.dataset.tagLabelEn
          : button.dataset.tagLabelKo;
        const nextBody = isEnglish()
          ? button.dataset.tagDescriptionEn
          : button.dataset.tagDescriptionKo;

        if (tagHintTitle instanceof HTMLElement && nextTitle) {
          tagHintTitle.textContent = nextTitle;
        }

        if (tagHintBody instanceof HTMLElement && nextBody) {
          tagHintBody.textContent = nextBody;
        }
      };

      const setActive = (group) => {
        const current = state[group];
        const isMulti = Array.isArray(current);

        buttons
          .filter((button) => button.getAttribute('data-filter-group') === group)
          .forEach((button) => {
            const optionValue = button.getAttribute('data-filter-value');
            const isActive = isMulti
              ? optionValue === 'all'
                ? current.length === 0
                : current.includes(optionValue)
              : optionValue === current;

            button.classList.toggle('archive-option-active', isActive);
            button.classList.toggle('archive-category-active', isActive);
            if (button instanceof HTMLButtonElement) {
              button.setAttribute('aria-pressed', String(isActive));
            }
          });
      };

      const getSortedItems = () => {
        const sorted = [...items].sort((a, b) => {
          const firstPeriod = Number(a.getAttribute('data-order') || 0);
          const secondPeriod = Number(b.getAttribute('data-order') || 0);
          const firstCategory = Number(a.getAttribute('data-category-order') || 0);
          const secondCategory = Number(b.getAttribute('data-category-order') || 0);
          const firstNumber = Number(a.getAttribute('data-number') || 0);
          const secondNumber = Number(b.getAttribute('data-number') || 0);
          const firstOrganization = a.getAttribute('data-organization') || '';
          const secondOrganization = b.getAttribute('data-organization') || '';
          let primary = firstNumber - secondNumber;

          if (state.sortBy === 'organization') {
            primary = firstOrganization.localeCompare(secondOrganization, 'ko');
          } else if (state.sortBy === 'category') {
            primary = firstCategory - secondCategory;
          }

          if (primary === 0) {
            return secondPeriod - firstPeriod;
          }

          return state.sortDirection === 'asc' ? primary : primary * -1;
        });

        return sorted;
      };

      const getGroupLabel = (item) => ({
        ko: item.getAttribute('data-category-label-ko') || item.getAttribute('data-category') || '',
        en: item.getAttribute('data-category-label-en') || item.getAttribute('data-category') || ''
      });

      const createGroupSummaryCard = (groupKey, label, itemsInGroup) => {
        const card = document.createElement('article');
        card.className = 'experience-group-summary-card';

        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'experience-group-summary-button';
        button.setAttribute(
          'aria-label',
          isEnglish()
            ? `Filter by ${label.en || groupKey}`
            : `${label.ko || groupKey} 분류로 보기`
        );

        const visual = document.createElement('span');
        visual.className = 'experience-group-summary-visual';

        const imageItem = itemsInGroup.find((item) => item.getAttribute('data-image-src'));
        const imageSrc = categoryImages[groupKey] || imageItem?.getAttribute('data-image-src');
        const imageAlt = isEnglish()
          ? `${label.en || groupKey} group representative image`
          : `${label.ko || groupKey} 그룹 대표 이미지`;

        if (imageSrc) {
          const image = document.createElement('img');
          image.src = imageSrc;
          image.alt = imageAlt;
          visual.append(image);
        } else {
          const fallback = document.createElement('span');
          fallback.className = 'experience-group-summary-fallback';
          fallback.textContent = (isEnglish() ? label.en : label.ko).slice(0, 2);
          visual.append(fallback);
        }

        const content = document.createElement('span');
        content.className = 'experience-group-summary-content';

        const titleRow = document.createElement('span');
        titleRow.className = 'experience-group-summary-title-row';

        const title = document.createElement('span');
        title.className = 'experience-group-summary-title';
        title.textContent = isEnglish() ? label.en : label.ko;

        const count = document.createElement('span');
        count.className = 'experience-group-summary-count';
        count.textContent = isEnglish() ? `${itemsInGroup.length} items` : `${itemsInGroup.length}개`;

        const description = document.createElement('span');
        description.className = 'experience-group-summary-description';
        const descriptionPair = categoryDescriptions[groupKey] || {
          ko: '이 분류에 해당하는 경험을 모아 봅니다.',
          en: 'View experiences in this category.'
        };
        description.textContent = isEnglish() ? descriptionPair.en : descriptionPair.ko;

        const latest = itemsInGroup[0];
        const latestTitle = latest?.querySelector('h3')?.textContent?.trim();
        const latestText = document.createElement('span');
        latestText.className = 'experience-group-summary-latest';
        latestText.textContent = latestTitle
          ? isEnglish()
            ? `Latest: ${latestTitle}`
            : `최근: ${latestTitle}`
          : '';

        titleRow.append(title, count);
        content.append(titleRow, description);
        if (latestText.textContent) content.append(latestText);
        button.append(visual, content);
        card.append(button);

        button.addEventListener('click', () => {
          state.category = [groupKey];
          state.grouping = 'none';
          state.view = 'card';
          resetVisibleLimit();
          setActive('category');
          setActive('grouping');
          setActive('view');
          apply();
        });

        return card;
      };

      const renderItems = (sortedItems) => {
        if (!(list instanceof HTMLElement)) return;

        list.replaceChildren();
        list.classList.toggle('experience-card-grid-list', state.grouping === 'none' && state.view === 'list');
        list.classList.toggle('experience-card-grid-group', state.grouping === 'category');
        list.classList.toggle('experience-card-grid-group-summary', state.grouping === 'category');
        list.classList.toggle('experience-card-grid-group-summary-list', state.grouping === 'category' && state.view === 'list');

        if (state.grouping !== 'category') {
          sortedItems.forEach((item) => list.append(item));
          return;
        }

        const groups = new Map();
        sortedItems
          .filter((item) => !item.hidden)
          .forEach((item) => {
            const groupKey = item.getAttribute('data-category') || 'uncategorized';
            const existing = groups.get(groupKey);

            if (existing) {
              existing.items.push(item);
              return;
            }

            groups.set(groupKey, {
              label: getGroupLabel(item),
              items: [item]
            });
          });

        groups.forEach((group, groupKey) => {
          list.append(createGroupSummaryCard(groupKey, group.label, group.items));
        });
      };

      const resetVisibleLimit = () => {
        state.visibleLimit = visiblePageSize;
      };

      const updatePagination = (matchedCount, shownCount) => {
        if (pagination instanceof HTMLElement) {
          pagination.hidden = matchedCount === 0 || matchedCount <= shownCount;
        }

        if (paginationCount instanceof HTMLElement) {
          paginationCount.setAttribute(
            'aria-label',
            isEnglish()
              ? `${matchedCount} filter results, ${items.length} total experiences`
              : `필터 결과 ${matchedCount}개, 경험 총개수 ${items.length}개`
          );
        }

        if (resultCount instanceof HTMLElement) {
          resultCount.textContent = String(matchedCount);
        }

        if (totalCount instanceof HTMLElement) {
          totalCount.textContent = String(items.length);
        }

        if (loadMoreButton instanceof HTMLButtonElement) {
          loadMoreButton.hidden = matchedCount <= shownCount;
        }

        if (showAllButton instanceof HTMLButtonElement) {
          showAllButton.hidden = matchedCount <= shownCount;
        }
      };

      const apply = () => {
        const query = search instanceof HTMLInputElement ? search.value.trim().toLowerCase() : '';
        const hasPeriodFilter = Boolean(state.periodStart || state.periodEnd);
        const selectedStart = state.periodStart ? `${state.periodStart}-01` : '0000-01-01';
        const selectedEnd = state.periodEnd ? toMonthRangeEnd(state.periodEnd) : '9999-12-31';
        const periodRangeStart = selectedStart <= selectedEnd ? selectedStart : selectedEnd;
        const periodRangeEnd = selectedStart <= selectedEnd ? selectedEnd : selectedStart;
        let matchedCount = 0;
        let shownCount = 0;

        const sortedItems = getSortedItems();

        sortedItems.forEach((item) => {
          const searchValue = item.getAttribute('data-search') || '';
          const category = item.getAttribute('data-category') || '';
          const status = item.getAttribute('data-status') || '';
          const periodRanges = (item.getAttribute('data-period-ranges') || '')
            .split('|')
            .map((range) => range.split('..'))
            .filter((range) => range.length === 2);
          const tags = (item.getAttribute('data-tags') || '').split(' ');
          const projectDomains = (item.getAttribute('data-project-domains') || '').split(' ');
          const techTags = (item.getAttribute('data-tech-tags') || '').split(' ');

          const matchesQuery = !query || searchValue.includes(query);
          const matchesPeriod =
            !hasPeriodFilter ||
            periodRanges.length === 0 ||
            periodRanges.some(([start, end]) => end >= periodRangeStart && start <= periodRangeEnd);
          const selectedCategories = Array.isArray(state.category) ? state.category : [];
          const selectedTags = Array.isArray(state.tag) ? state.tag : [];
          const selectedProjectDomains = Array.isArray(state.projectDomain) ? state.projectDomain : [];
          const selectedTechTags = Array.isArray(state.techTag) ? state.techTag : [];
          const matchesCategory =
            selectedCategories.length === 0 || selectedCategories.includes(category);
          const matchesStatus = state.status === 'all' || status === state.status;
          const matchesTag =
            selectedTags.length === 0 || selectedTags.some((tag) => tags.includes(tag));
          const matchesProjectDomain =
            selectedProjectDomains.length === 0 ||
            selectedProjectDomains.some((domain) => projectDomains.includes(domain));
          const matchesTechTag =
            selectedTechTags.length === 0 || selectedTechTags.some((tag) => techTags.includes(tag));
          const isVisible =
            matchesQuery &&
            matchesPeriod &&
            matchesCategory &&
            matchesStatus &&
            matchesTag &&
            matchesProjectDomain &&
            matchesTechTag;
          let shouldShow = false;

          if (isVisible) {
            matchedCount += 1;
            shouldShow = state.grouping === 'category'
              ? true
              : matchedCount <= state.visibleLimit;
            if (shouldShow) shownCount += 1;
          }

          item.toggleAttribute('hidden', !shouldShow);
        });

        if (empty instanceof HTMLElement) {
          empty.hidden = matchedCount !== 0;
        }

        renderItems(sortedItems);

        updatePagination(matchedCount, shownCount);
      };

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const group = button.getAttribute('data-filter-group');
          const value = button.getAttribute('data-filter-value');
          if (!group || !value || !(group in state)) return;

          const current = state[group];

          if (Array.isArray(current)) {
            state[group] = value === 'all'
              ? []
              : current.includes(value)
                ? current.filter((selectedValue) => selectedValue !== value)
                : [...current, value];
          } else {
            state[group] = value;
          }

          if (!['sortBy', 'sortDirection', 'view', 'grouping'].includes(group)) {
            resetVisibleLimit();
          }

          setActive(group);
          if (group === 'tag') {
            const selectedTags = Array.isArray(state.tag) ? state.tag : [];
            if (value !== 'all' && selectedTags.includes(value)) {
              setTagHint(button);
            } else {
              resetTagHint();
            }
          }
          apply();
        });
      });

      if (sortByTrigger instanceof HTMLButtonElement) {
        sortByTrigger.addEventListener('click', (event) => {
          event.stopPropagation();
          const isOpen = sortByTrigger.getAttribute('aria-expanded') === 'true';
          setSortByMenuOpen(!isOpen);
        });
      }

      sortByOptions.forEach((option) => {
        if (!(option instanceof HTMLButtonElement)) return;

        option.addEventListener('click', (event) => {
          event.stopPropagation();
          const value = option.getAttribute('data-archive-sort-by-option');
          if (!value || !(value in sortByLabels)) return;

          state.sortBy = value;
          updateSortByControl();
          setSortByMenuOpen(false);
          apply();
        });
      });

      document.addEventListener('click', (event) => {
        if (
          event.target instanceof Node &&
          (sortByTrigger?.contains(event.target) || sortByMenu?.contains(event.target))
        ) {
          return;
        }

        setSortByMenuOpen(false);
      });

      tagButtons.forEach((button) => {
        if (!(button instanceof HTMLElement)) return;

        button.addEventListener('mouseenter', () => setTagHint(button));
        button.addEventListener('focus', () => setTagHint(button));
        button.addEventListener('mouseleave', resetTagHint);
        button.addEventListener('blur', resetTagHint);
      });

      dateTriggers.forEach((trigger) => {
        if (!(trigger instanceof HTMLButtonElement)) return;

        trigger.addEventListener('click', (event) => {
          event.stopPropagation();
          const field = trigger.getAttribute('data-date-trigger');
          if (!field || !(field in state)) return;

          if (activeCalendar === field) {
            closeCalendars();
            return;
          }

          openCalendar(field);
        });
      });

      calendarPopovers.forEach((popover) => {
        popover.addEventListener('click', (event) => {
          event.stopPropagation();
          const field = popover.getAttribute('data-calendar-popover');
          if (!field || !(field in state)) return;

          const target = event.target instanceof Element
            ? event.target.closest('[data-calendar-month], [data-calendar-action]')
            : null;
          if (!(target instanceof HTMLElement)) return;

          const action = target.getAttribute('data-calendar-action');
          if (action === 'prev' || action === 'next') {
            const current = calendarState[field];
            const direction = action === 'prev' ? -1 : 1;
            calendarState[field] = new Date(current.getFullYear() + direction, current.getMonth(), 1);
            renderCalendar(field);
            return;
          }

          if (action === 'clear') {
            setDateValue(field, '');
            closeCalendars();
            return;
          }

          if (action === 'today') {
            const todayValue = toMonthValue(today);
            calendarState[field] = new Date(today.getFullYear(), today.getMonth(), 1);
            setDateValue(field, todayValue);
            closeCalendars();
            return;
          }

          const value = target.getAttribute('data-calendar-month');
          if (value) {
            setDateValue(field, value);
            closeCalendars();
          }
        });
      });

      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target : null;
        if (target?.closest('[data-date-trigger], [data-calendar-popover]')) return;
        closeCalendars();
      });

      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;
        closeCalendars();
        setMobileFilterOpen(false);
      });

      if (search instanceof HTMLInputElement) {
        search.addEventListener('input', () => {
          syncSearchInputs(search.value, search);
          resetVisibleLimit();
          apply();
        });
      }

      if (mobileSearch instanceof HTMLInputElement) {
        mobileSearch.addEventListener('input', () => {
          syncSearchInputs(mobileSearch.value, mobileSearch);
          resetVisibleLimit();
          apply();
        });
      }

      if (loadMoreButton instanceof HTMLButtonElement) {
        loadMoreButton.addEventListener('click', () => {
          state.visibleLimit += visiblePageSize;
          apply();
        });
      }

      if (showAllButton instanceof HTMLButtonElement) {
        showAllButton.addEventListener('click', () => {
          state.visibleLimit = items.length;
          apply();
        });
      }

      if (railToggle instanceof HTMLButtonElement) {
        railToggle.addEventListener('click', () => {
          const isCollapsed = root.getAttribute('data-sidebar-collapsed') === 'true';
          setSidebarCollapsed(!isCollapsed);
        });
      }

      if (categoryToggle instanceof HTMLButtonElement) {
        categoryToggle.addEventListener('click', () => {
          const isCollapsed = root.getAttribute('data-category-collapsed') === 'true';
          setCategoryCollapsed(!isCollapsed);
        });
      }

      if (tagToggle instanceof HTMLButtonElement) {
        tagToggle.addEventListener('click', () => {
          const isCollapsed = root.getAttribute('data-tag-collapsed') === 'true';
          setTagCollapsed(!isCollapsed);
        });
      }

      if (projectFilterToggle instanceof HTMLButtonElement) {
        projectFilterToggle.addEventListener('click', () => {
          const isCollapsed = root.getAttribute('data-project-filter-collapsed') === 'true';
          setProjectFilterCollapsed(!isCollapsed);
        });
      }

      if (mobileFilterOpenButton instanceof HTMLButtonElement) {
        mobileFilterOpenButton.addEventListener('click', () => setMobileFilterOpen(true));
      }

      if (mobileFilterCloseButton instanceof HTMLButtonElement) {
        mobileFilterCloseButton.addEventListener('click', () => setMobileFilterOpen(false));
      }

      if (mobileFilterBackdrop instanceof HTMLButtonElement) {
        mobileFilterBackdrop.addEventListener('click', () => setMobileFilterOpen(false));
      }

      mobileFilterMedia.addEventListener('change', (event) => {
        if (!event.matches) setMobileFilterOpen(false);
      });

      const languageObserver = new MutationObserver(() => {
        updateDateDisplays();
        updateSortByControl();
        resetTagHint();
        if (activeCalendar) renderCalendar(activeCalendar);
        setSidebarCollapsed(root.getAttribute('data-sidebar-collapsed') === 'true');
        setCategoryCollapsed(root.getAttribute('data-category-collapsed') === 'true');
        setTagCollapsed(root.getAttribute('data-tag-collapsed') === 'true');
        setProjectFilterCollapsed(root.getAttribute('data-project-filter-collapsed') === 'true');
        apply();
      });

      languageObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['lang']
      });

      updateDateDisplays();
      updateSortByControl();
      resetTagHint();
      ['status', 'category', 'tag', 'projectDomain', 'techTag', 'sortBy', 'sortDirection', 'grouping', 'view'].forEach((group) => setActive(group));
      setSidebarCollapsed(false);
      setCategoryCollapsed(false);
      setTagCollapsed(false);
      setProjectFilterCollapsed(true);
      setMobileFilterOpen(false);
      archiveContent?.addEventListener('scroll', updateListHeaderState, { passive: true });
      window.addEventListener('scroll', updateListHeaderState, { passive: true });
      observeListHeaderState();
      updateListHeaderState();
      window.requestAnimationFrame(syncListHeaderState);
      apply();
    })();
  </script>
</BaseLayout>
